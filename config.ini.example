[database]
url = postgresql://user:password@host:port/dbname

[path]
linux_prefix  = /root/BestShot/
windows_drive = Z

[tables]
bhvr_table = t_bhvr_anly
dst_table  = t_dst_anly
event_col  = evnt_knd

[events]
bhvr = 침입,배회,쓰러짐,싸움,보행자위험
dst  = 침수,화재,연기,열감지

[api]
base_url = http://0.0.0.0:8000

[mariadb]
host     = 0.0.0.0
port     = 3306
user     = username
password = password
database = dbname
table    = NTbl_User
id_col   = UserID
name_col = UserName
